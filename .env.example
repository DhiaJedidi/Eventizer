# ─── Payload ───────────────────────────────────────────────────────────────
# Required. Long random string used to sign/encrypt. Generate: openssl rand -base64 32
PAYLOAD_SECRET=

# Database (SQLite via libSQL). Dev: a local file. Prod (Vercel): a Turso libSQL URL.
# Dev example:
DATABASE_URI=file:./eventizer.db
# Prod example (Turso): DATABASE_URI=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=

# ─── Media storage (production only) ─────────────────────────────────────────
# Vercel Blob read/write token. Dev uses the local filesystem and ignores this.
BLOB_READ_WRITE_TOKEN=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender + destination for contact-form notifications
CONTACT_FROM_EMAIL=Eventizer <contact@eventizer.tn>
CONTACT_TO_EMAIL=contact@eventizer.tn

# ─── Site / analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.eventizer.tn
NEXT_PUBLIC_GA_ID=
